# NelsonGPT Environment Variables
# Copy this file to .env and fill in your actual values

# Mistral AI API Configuration
VITE_MISTRAL_API_KEY=your_mistral_api_key_here
VITE_MISTRAL_API_URL=https://api.mistral.ai/v1

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: OpenAI API (for embeddings or fallback)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
VITE_APP_NAME=NelsonGPT
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="Evidence-based pediatric medical assistant"

# Development Configuration
VITE_DEV_MODE=true
VITE_LOG_LEVEL=info

# Medical Features Configuration
VITE_ENABLE_DRUG_CALCULATOR=true
VITE_ENABLE_SYMPTOM_ANALYZER=true
VITE_ENABLE_EMERGENCY_PROTOCOLS=true
VITE_ENABLE_CITATIONS=true

# RAG Configuration
VITE_RAG_MAX_CHUNKS=5
VITE_RAG_SIMILARITY_THRESHOLD=0.7
VITE_RAG_CHUNK_SIZE=1500

# Chat Configuration
VITE_MAX_CHAT_HISTORY=100
VITE_MAX_MESSAGE_LENGTH=4000
VITE_TYPING_DELAY=50

# PWA Configuration
VITE_PWA_ENABLED=true
VITE_OFFLINE_ENABLED=true

# Analytics (Optional)
VITE_ANALYTICS_ID=your_analytics_id_here
VITE_ENABLE_ANALYTICS=false

# Security
VITE_ENABLE_RATE_LIMITING=true
VITE_MAX_REQUESTS_PER_MINUTE=30

# Medical Disclaimer
VITE_SHOW_MEDICAL_DISCLAIMER=true
VITE_DISCLAIMER_TEXT="This tool is for educational purposes only and should not replace professional medical judgment."

